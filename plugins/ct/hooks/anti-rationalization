#!/usr/bin/env bash
# PreToolUse hook (matcher: TodoWrite|TaskUpdate): blocks task completion
# when the assistant's recent messages contain rationalization patterns.
#
# Fires when EITHER:
#   - TaskUpdate sets .tool_input.status == "completed"  (top-level field)
#   - TodoWrite contains any .tool_input.todos[] item with .status == "completed"
#
# Reads the JSONL transcript to extract the last assistant message, then
# checks for phrases that indicate incomplete work being waved away.

set -euo pipefail

INPUT=$(cat)

# Only act when marking a task as completed.
# Handles both payload shapes:
#   - TaskUpdate: .tool_input.status (top-level)
#   - TodoWrite:  .tool_input.todos[] with .status == "completed"
# Note: `// ""` (not `// empty`) — `empty` short-circuits the pipeline before
# the elif branch can run, silently disabling the TodoWrite path.
COMPLETED=$(echo "$INPUT" | jq -r '
  if (.tool_input.status // "") == "completed" then "yes"
  elif ((.tool_input.todos // []) | map(select(.status == "completed")) | length) > 0 then "yes"
  else "no"
  end
')
if [[ "$COMPLETED" != "yes" ]]; then
  exit 0
fi

TRANSCRIPT=$(echo "$INPUT" | jq -r '.transcript_path // empty')
if [[ -z "$TRANSCRIPT" || ! -f "$TRANSCRIPT" ]]; then
  exit 0
fi

# Extract the most recent assistant text content block from the JSONL transcript.
# Notes on the filter:
#   - Role lives at `.message.role`; top-level `.role` is null (checked against
#     Claude Code's JSONL schema). The old filter `select(.role == "assistant")`
#     silently matched nothing, so the hook was a no-op.
#   - Each content block (text/thinking/tool_use) is its own JSONL line. At
#     PreToolUse time the most recent assistant line is the pending tool_use
#     itself, so we have to walk back past tool_use/thinking blocks and match
#     on the most recent `text` block.
# `-c` (not `-r`) emits each text block as a single JSON-encoded line so
# `head -n 1` picks one whole block instead of truncating multi-line text at
# the first newline. Substring matching against the JSON-quoted form still
# works for the patterns below (they contain no escape-sensitive chars).
LAST_MSG=$(tac "$TRANSCRIPT" \
  | jq -c 'select(.message.role == "assistant")
           | .message.content[]?
           | select(.type == "text")
           | .text' 2>/dev/null \
  | head -n 1)

if [[ -z "$LAST_MSG" ]]; then
  exit 0
fi

# Rationalization patterns (case-insensitive, substring match)
# Patterns derived from empirical scan of history.jsonl (2026-04-17).
PATTERNS=(
  # --- Scope dismissal
  'out of scope'
  'beyond the scope'
  'outside the scope'
  'avoid scope creep'
  'unrelated to this'
  'unrelated to the'

  # --- Authorship-based dismissal
  'pre-existing'
  'pre existing'
  'not introduced by'
  'not my change'
  'not my regression'
  'not my concern'

  # --- Explicit deferral
  'follow-up task'
  'follow up task'
  'separate follow-up'
  'separate follow up'
  'address later'
  'fix later'
  'defer to'
  'leave for now'
  'skip for now'
  'tackle later'
  'revisit later'
  'in a later task'

  # --- Value dismissal
  'too many issues'
  'too many errors'
  'not going to fix'
  'not worth'
  'nice-to-have'
  'nice to have'
  'low-value'
  'low value'
  'not critical'
  'not a blocker'
  'not blocking'
  'acceptable trade-off'
  'acceptable given'
)

LOWER_MSG=$(echo "$LAST_MSG" | tr '[:upper:]' '[:lower:]')

for pattern in "${PATTERNS[@]}"; do
  if [[ "$LOWER_MSG" == *"$pattern"* ]]; then
    echo "Anti-rationalization check failed: detected '$pattern' in recent response. Do not mark this task complete if work remains unfinished. Go back and finish the work, or explain to the user why completion is genuinely blocked." >&2
    exit 2
  fi
done

exit 0
