{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "voiceEnabled": true,
  "autoMemoryEnabled": false,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '## Active Shell Aliases' && cat ~/.claude/shell-aliases.txt 2>/dev/null"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Write(/tmp)",
      "WebSearch"
    ],
    "deny": [
      "Read(/etc/passwd)",
      "Read(/etc/shadow)",
      "Read(/etc/hosts)",
      "Read(/etc/sudoers)",
      "Read(/etc/sudoers.d/**)",
      "Read(/etc/pam.d/**)",
      "Read(/etc/security/**)",
      "Read(/etc/ssh/**)",
      "Read(/etc/ssl/private/**)",
      "Read(/private/etc/passwd)",
      "Read(/private/etc/shadow)",
      "Read(/private/etc/hosts)",
      "Read(/private/etc/sudoers)",
      "Read(/private/etc/sudoers.d/**)",
      "Read(/private/etc/pam.d/**)",
      "Read(/private/etc/security/**)",
      "Read(/private/etc/ssh/**)",
      "Read(/private/etc/ssl/private/**)",
      "Read(/var/db/dslocal/nodes/Default/users/**)",
      "Read(/root/.ssh/**)",
      "Bash(rm -rf:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shred:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git update-ref -d:*)"
    ],
    "ask": [
    ]
  }
}
